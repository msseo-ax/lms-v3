generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──────────────────────────────────────

enum Role {
  admin
  user
}

enum FileType {
  pdf
  docx
  mp4
  audio
  image
  link
}

enum TargetType {
  all
  division
  team
  user
}

// ── Organization ───────────────────────────────

model Division {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  teams     Team[]
  users     User[]

  @@map("divisions")
}

model Team {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(100)
  divisionId String   @map("division_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  users      User[]

  @@map("teams")
}

// ── User ───────────────────────────────────────

model User {
  id             String           @id @default(uuid()) @db.Uuid
  email          String           @unique @db.VarChar(255)
  name           String           @db.VarChar(100)
  role           Role             @default(user)
  divisionId     String?          @map("division_id") @db.Uuid
  teamId         String?          @map("team_id") @db.Uuid
  avatarUrl      String?          @map("avatar_url")
  slackUserId    String?          @map("slack_user_id") @db.VarChar(50)
  createdAt      DateTime         @default(now()) @map("created_at")
  division       Division?        @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  team           Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  contents       Content[]
  readLogs       ReadLog[]
  fileAccessLogs FileAccessLog[]

  @@index([divisionId])
  @@index([teamId])
  @@map("users")
}

// ── Content ────────────────────────────────────

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  slug      String    @unique @db.VarChar(50)
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  contents  Content[]

  @@map("categories")
}

model Content {
  id                 String          @id @default(uuid()) @db.Uuid
  title              String          @db.VarChar(255)
  body               String?         @db.Text
  summary            String?         @db.Text
  categoryId         String          @map("category_id") @db.Uuid
  createdBy          String          @map("created_by") @db.Uuid
  minDurationSeconds Int             @default(10) @map("min_duration_seconds")
  requireFileAccess  Boolean         @default(false) @map("require_file_access")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  category           Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author             User            @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  files              ContentFile[]
  targets            ContentTarget[]
  readLogs           ReadLog[]

  @@index([categoryId])
  @@index([createdAt])
  @@map("contents")
}

model ContentFile {
  id         String          @id @default(uuid()) @db.Uuid
  contentId  String          @map("content_id") @db.Uuid
  fileUrl    String          @map("file_url")
  fileType   FileType        @map("file_type")
  fileName   String          @map("file_name") @db.VarChar(255)
  fileSize   Int             @map("file_size")
  createdAt  DateTime        @default(now()) @map("created_at")
  content    Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  accessLogs FileAccessLog[]

  @@index([contentId])
  @@map("content_files")
}

model ContentTarget {
  id         String     @id @default(uuid()) @db.Uuid
  contentId  String     @map("content_id") @db.Uuid
  targetType TargetType @map("target_type")
  targetId   String?    @map("target_id") @db.Uuid
  content    Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([targetType, targetId])
  @@map("content_targets")
}

// ── Tracking ───────────────────────────────────

model ReadLog {
  id              String   @id @default(uuid()) @db.Uuid
  contentId       String   @map("content_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  readAt          DateTime @default(now()) @map("read_at")
  durationSeconds Int      @default(0) @map("duration_seconds")
  content         Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([contentId])
  @@map("read_logs")
}

model FileAccessLog {
  id            String      @id @default(uuid()) @db.Uuid
  contentFileId String      @map("content_file_id") @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  accessedAt    DateTime    @default(now()) @map("accessed_at")
  contentFile   ContentFile @relation(fields: [contentFileId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contentFileId])
  @@index([userId])
  @@map("file_access_logs")
}
