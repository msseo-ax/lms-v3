generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──────────────────────────────────────

enum Role {
  admin
  user
}

enum FileType {
  pdf
  docx
  pptx
  xlsx
  mp4
  audio
  image
  link
}

enum TargetType {
  all
  division
  team
  user
}

enum QuestionType {
  multiple_choice
  short_answer
}

// ── Organization ───────────────────────────────

model Division {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  teams     Team[]
  users     User[]

  @@map("divisions")
}

model Team {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(100)
  divisionId String   @map("division_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  users      User[]

  @@map("teams")
}

// ── User ───────────────────────────────────────

model User {
  id             String           @id @default(uuid()) @db.Uuid
  email          String           @unique @db.VarChar(255)
  name           String           @db.VarChar(100)
  role           Role             @default(user)
  divisionId     String?          @map("division_id") @db.Uuid
  teamId         String?          @map("team_id") @db.Uuid
  avatarUrl      String?          @map("avatar_url")
  slackUserId    String?          @map("slack_user_id") @db.VarChar(50)
  createdAt      DateTime         @default(now()) @map("created_at")
  division       Division?        @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  team           Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  contents       Content[]
  readLogs       ReadLog[]
  fileAccessLogs FileAccessLog[]
  quizAttempts   QuizAttempt[]

  @@index([divisionId])
  @@index([teamId])
  @@map("users")
}

// ── Content ────────────────────────────────────

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  slug      String    @unique @db.VarChar(50)
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  contents  Content[]

  @@map("categories")
}

model Content {
  id         String          @id @default(uuid()) @db.Uuid
  title      String          @db.VarChar(255)
  body       String?         @db.Text
  summary    String?         @db.Text
  categoryId String          @map("category_id") @db.Uuid
  createdBy  String          @map("created_by") @db.Uuid
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author     User            @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  files      ContentFile[]
  targets    ContentTarget[]
  readLogs   ReadLog[]
  quiz       Quiz?

  @@index([categoryId])
  @@index([createdAt])
  @@map("contents")
}

model ContentFile {
  id         String          @id @default(uuid()) @db.Uuid
  contentId  String          @map("content_id") @db.Uuid
  fileUrl    String          @map("file_url")
  fileType   FileType        @map("file_type")
  fileName   String          @map("file_name") @db.VarChar(255)
  fileSize   Int             @map("file_size")
  createdAt  DateTime        @default(now()) @map("created_at")
  content    Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  accessLogs FileAccessLog[]

  @@index([contentId])
  @@map("content_files")
}

model ContentTarget {
  id         String     @id @default(uuid()) @db.Uuid
  contentId  String     @map("content_id") @db.Uuid
  targetType TargetType @map("target_type")
  targetId   String?    @map("target_id") @db.Uuid
  content    Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([targetType, targetId])
  @@map("content_targets")
}

// ── Tracking ───────────────────────────────────

model ReadLog {
  id        String   @id @default(uuid()) @db.Uuid
  contentId String   @map("content_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  readAt    DateTime @default(now()) @map("read_at")
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([contentId])
  @@map("read_logs")
}

model FileAccessLog {
  id            String      @id @default(uuid()) @db.Uuid
  contentFileId String      @map("content_file_id") @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  accessedAt    DateTime    @default(now()) @map("accessed_at")
  contentFile   ContentFile @relation(fields: [contentFileId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contentFileId])
  @@index([userId])
  @@map("file_access_logs")
}

// ── Quiz ──────────────────────────────────────

model Quiz {
  id           String        @id @default(uuid()) @db.Uuid
  contentId    String        @unique @map("content_id") @db.Uuid
  passingScore Int           @default(80) @map("passing_score")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  content      Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  questions    Question[]
  attempts     QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id            String       @id @default(uuid()) @db.Uuid
  quizId        String       @map("quiz_id") @db.Uuid
  type          QuestionType
  text          String       @db.Text
  options       Json?
  correctAnswer String       @map("correct_answer") @db.Text
  keywords      String[]
  sortOrder     Int          @default(0) @map("sort_order")
  createdAt     DateTime     @default(now()) @map("created_at")
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers       QuizAnswer[]

  @@index([quizId])
  @@map("questions")
}

model QuizAttempt {
  id          String       @id @default(uuid()) @db.Uuid
  quizId      String       @map("quiz_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  score       Int
  passed      Boolean
  completedAt DateTime     @default(now()) @map("completed_at")
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     QuizAnswer[]

  @@index([quizId])
  @@index([userId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id         String      @id @default(uuid()) @db.Uuid
  attemptId  String      @map("attempt_id") @db.Uuid
  questionId String      @map("question_id") @db.Uuid
  answer     String      @db.Text
  isCorrect  Boolean     @map("is_correct")
  attempt    QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@map("quiz_answers")
}
